// schema.prisma — CrossFit Turnos (multi-tenant B2B2C)
// Decisión: un Gym es el root tenant. Cada gym tiene usuarios, clases y coaches.
// Soft-delete en GymClass y Booking para conservar historial sin perder datos.
// Booking es por fecha concreta (classDate), no recurrente — el alumno reserva
// para UN día específico, no "todos los lunes".

generator client {
  provider = "prisma-client-js"
}

// Decisión Prisma v7: la URL se configura en prisma.config.ts, no aquí.
// Ver: https://pris.ly/d/config-datasource
datasource db {
  provider = "postgresql"
}

// ─── ENUMS ────────────────────────────────────────────────────────────────────

enum Role {
  ADMIN
  COACH
  STUDENT
}

enum BookingStatus {
  CONFIRMED
  CANCELLED
  WAITLISTED
}

enum PaymentStatus {
  PENDING    // preferencia creada, esperando pago
  APPROVED   // webhook confirmó pago
  REJECTED   // pago rechazado
  CANCELLED  // usuario canceló en checkout
  REFUNDED   // devolución procesada
}

enum CreditTxType {
  PURCHASE    // +N al comprar un pack
  CONSUME     // -1 al confirmar una reserva
  REFUND      // +1 al cancelar dentro de ventana
  EXPIRY      // -N al vencer (cron job)
  ADJUSTMENT  // corrección manual por admin
}

enum DayOfWeek {
  MONDAY
  TUESDAY
  WEDNESDAY
  THURSDAY
  FRIDAY
  SATURDAY
  SUNDAY
}

// ─── GYM (root del tenant) ────────────────────────────────────────────────────

model Gym {
  id        String   @id @default(cuid())
  name      String
  slug      String   @unique // "crossfit-norte" → subdomain o path
  logoUrl   String?
  address   String?
  phone     String?
  timezone  String   @default("America/Argentina/Buenos_Aires")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users   User[]
  classes GymClass[]

  // Billing
  cancelWindowHours Int @default(2) // ventana para cancelar con reembolso de crédito
  packs          Pack[]
  payments       Payment[]
  creditBalances UserCreditBalance[]

  @@map("gyms")
}

// ─── USER ─────────────────────────────────────────────────────────────────────

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  image         String?
  role          Role      @default(STUDENT)
  passwordHash  String?   // null si usa OAuth (Google, etc.)
  isActive      Boolean   @default(true)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  gymId String?
  gym   Gym?    @relation(fields: [gymId], references: [id], onDelete: SetNull)

  bookings      Booking[]
  taughtClasses GymClass[] @relation("CoachClasses")

  // Billing
  payments        Payment[]
  creditBalances  UserCreditBalance[]
  creditTxs       CreditTransaction[]

  // NextAuth adapters
  accounts Account[]
  sessions Session[]

  @@map("users")
}

// ─── NEXTAUTH ─────────────────────────────────────────────────────────────────

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

// ─── GYM CLASS ────────────────────────────────────────────────────────────────

model GymClass {
  id          String    @id @default(cuid())
  name        String    // "CrossFit WOD", "Open Box", "Weightlifting"
  description String?
  dayOfWeek   DayOfWeek
  startTime   String    // "07:00" HH:mm en timezone del gym
  endTime     String    // "08:00"
  maxCapacity Int       @default(12)
  color       String?   // hex para UI — diferencia tipos de clase visualmente
  isActive    Boolean   @default(true)
  deletedAt   DateTime? // soft delete — preserva historial de bookings

  gymId   String
  gym     Gym    @relation(fields: [gymId], references: [id], onDelete: Cascade)
  coachId String?
  coach   User?  @relation("CoachClasses", fields: [coachId], references: [id], onDelete: SetNull)

  bookings Booking[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([gymId, dayOfWeek])
  @@index([gymId, isActive])
  @@map("gym_classes")
}

// ─── BOOKING ──────────────────────────────────────────────────────────────────

model Booking {
  id          String        @id @default(cuid())
  status      BookingStatus @default(CONFIRMED)
  classDate   DateTime      // fecha del turno (se guarda a medianoche UTC del día)
  waitlistPos Int?          // posición en espera si status=WAITLISTED; null si CONFIRMED
  cancelledAt DateTime?     // timestamp de cancelación
  deletedAt   DateTime?     // soft delete

  userId  String
  user    User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  classId String
  class   GymClass @relation(fields: [classId], references: [id], onDelete: Cascade)

  creditTxs CreditTransaction[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Restricción: un usuario no puede tener dos bookings para la misma clase el mismo día
  @@unique([userId, classId, classDate])
  @@index([classId, classDate, status]) // consulta frecuente: cupos disponibles
  @@index([userId, classDate])          // consulta frecuente: mis turnos del día
  @@map("bookings")
}

// ─── BILLING ──────────────────────────────────────────────────────────────────

// Pack — el gym define sus packs y precios (multi-tenant)
model Pack {
  id           String   @id @default(cuid())
  gymId        String
  gym          Gym      @relation(fields: [gymId], references: [id], onDelete: Cascade)
  name         String   // "Pack 8 clases"
  credits      Int      // 8 | 12 | 16
  price        Decimal  @db.Decimal(10, 2)
  currency     String   @default("ARS")
  validityDays Int?     // días desde compra; null = sin vencimiento
  isActive     Boolean  @default(true)
  sortOrder    Int      @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  payments Payment[]

  @@index([gymId, isActive])
  @@map("packs")
}

// Payment — registro de cada intento/compra de pack
model Payment {
  id                String        @id @default(cuid())
  gymId             String
  userId            String
  packId            String

  creditsGranted    Int           // snapshot del pack al momento de compra
  amountPaid        Decimal       @db.Decimal(10, 2)
  currency          String        @default("ARS")

  provider          String        @default("MERCADOPAGO")
  providerPaymentId String?       @unique  // payment_id de MP — garantiza idempotencia
  providerOrderId   String?                // preference_id (URL de checkout)

  status            PaymentStatus @default(PENDING)
  expiresAt         DateTime?     // cuándo vencen los créditos de este pago

  rawWebhook        Json?         // payload del webhook (auditoría)
  failureReason     String?
  paidAt            DateTime?

  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt

  gym          Gym               @relation(fields: [gymId], references: [id])
  user         User              @relation(fields: [userId], references: [id])
  pack         Pack              @relation(fields: [packId], references: [id])
  creditTxs    CreditTransaction[]

  @@index([userId, gymId])
  @@index([providerPaymentId])
  @@index([gymId, status])
  @@map("payments")
}

// UserCreditBalance — balance materializado para reads O(1)
// SIEMPRE se actualiza dentro de la misma transacción que el CreditTransaction
model UserCreditBalance {
  id               String   @id @default(cuid())
  userId           String
  gymId            String
  availableCredits Int      @default(0)
  version          Int      @default(0) // optimistic locking
  updatedAt        DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  gym  Gym  @relation(fields: [gymId], references: [id], onDelete: Cascade)

  @@unique([userId, gymId])
  @@map("user_credit_balances")
}

// CreditTransaction — ledger append-only, fuente de verdad para auditoría
model CreditTransaction {
  id        String       @id @default(cuid())
  userId    String
  gymId     String
  type      CreditTxType
  amount    Int          // positivo = acreditar, negativo = consumir
  paymentId String?      // presente en PURCHASE
  bookingId String?      // presente en CONSUME y REFUND
  expiresAt DateTime?    // copia de Payment.expiresAt para queries de vencimiento
  note      String?      // obligatorio en ADJUSTMENT
  createdAt DateTime     @default(now())

  user    User     @relation(fields: [userId], references: [id])
  payment Payment? @relation(fields: [paymentId], references: [id])
  booking Booking? @relation(fields: [bookingId], references: [id])

  @@index([userId, gymId, createdAt])
  @@index([bookingId])
  @@map("credit_transactions")
}
